---
import { Grip } from "@lucide/astro";
import { Button } from "@/components/starwind/button";
const navItems = [
    { name: "Projects", href: "/projects" },
    { name: "About", href: "/about" },
    { name: "Contact", href: "/contact" },
];
---

<nav class="grid grid-cols-2 grid-rows-3 max-w-6xl mx-auto gap-6">
    <div class="col-span-2 md:col-span-1 flex flex-col">
        <a href="/" class="font-bold text-2xl md:text-6xl"
            ><p
                class="flex justify-center items-center gap-4 hover:bg-black hover:text-white"
            >
                <span
                    class="inline-flex items-center justify-center bg-black rounded p-2"
                >
                    <Grip class="h-8 w-8 md:h-14 md:w-20 text-white" />
                </span>
                <span>Cody Venditto</span>
            </p>
        </a>
        <p
            class="hidden md:flex justify-center md:justify-center text-gray-400 text-md md:text-2xl"
        >
            Aspiring Web Developer
        </p>
    </div>
    <div
        class="col-start-1 row-start-2 col-span-2 md:row-start-1 md:col-start-2 md:col-span-1 flex items-center md:justify-end justify-center"
    >
        <ul class="flex items-center gap-8 text-md md:text-xl">
            {
                navItems.map((item) => {
                    if (item.name === "Contact") {
                        return (
                            <li class="hover:text-blue-300">
                                <a href={item.href}>
                                    <Button
                                        class="bg-white text-black border border-black hover:bg-black hover:text-white transition-colors text-md"
                                        size="md"
                                    >
                                        {item.name}
                                    </Button>
                                </a>
                            </li>
                        );
                    } else {
                        return (
                            <li class="hover:text-gray-400">
                                <a href={item.href}>{item.name}</a>
                            </li>
                        );
                    }
                })
            }
        </ul>
    </div>
    <div class="md:row-start-2 row-start-3 col-span-2">
        <hr class="w-full" />
    </div>
</nav>
