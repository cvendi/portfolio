---
import { Button } from "@/components/starwind/button";
import { Badge } from "@/components/starwind/badge";
import { Image } from "astro:assets";
import {
    CircleUserRound,
    CircleCheckBig,
    ShieldPlus,
    Gauge,
    ArrowBigRight,
} from "@lucide/astro";
import JupiterImage from "@/assets/jupiter.png";
import CodyImage from "@/assets/cody.jpg";
---

<section
    id="hero"
    class="flex flex-col max-w-7xl mx-auto p-6 space-y-12 mt-16 md:mt-24 min-h-screen"
>
    <div class="flex flex-col md:flex-row items-center gap-10">
        <div
            class="flex flex-col items-center md:items-start gap-6 text-center md:text-left md:flex-1"
        >
            <p class="text-4xl md:text-6xl">
                Fast, professional websites for small businesses — built to help
                your customers find you and trust you.
            </p>
            <Button
                href="#projects"
                size="lg"
                class="dark:bg-white dark:text-black dark:border-black dark:hover:bg-black dark:hover:text-white dark:hover:border-white bg-black text-white border border-black hover:bg-white hover:text-black mt-6"
                >See my work</Button
            >
        </div>
        <Image
            src={JupiterImage}
            alt="Jupiter"
            class="w-3/4 md:w-2/5 rounded-lg shadow-lg object-cover self-center md:self-stretch"
        />
    </div>

    <hr class="max-w-7xl mt-24" />
    <div
        id="about"
        class="flex flex-col md:flex-row h-full items-center md:items-start gap-8 mt-24"
    >
        <Image
            src={CodyImage}
            alt="Cody Venditto"
            class="rounded-lg border-6 border-black w-2/3 md:w-1/5"
        />
        <div class="space-y-8 max-w-2xl">
            <div class="flex flex-col md:flex-row items-center gap-4">
                <h2 class="text-2xl font-semibold flex items-center gap-2">
                    <CircleUserRound /> About Me
                </h2>
                <Badge variant="success"
                    ><CircleCheckBig /> Available for new projects</Badge
                >
            </div>
            <p>I'm Cody, a web developer in Connecticut.</p>
            <p>
                I build fast, professional websites for small businesses, the
                kind that show customers who you are, what you offer, and how to
                reach you. I'm using the latest technologies to ensure your site
                is fast, secure, and works well on all devices.
            </p>
        </div>
    </div>
    <hr class="max-w-7xl mt-24" />
    <div class="mt-24 mb-24 grid gap-12 text-left md:grid-cols-3">
        <div class="flex flex-col">
            <h2 class="text-2xl font-semibold gap-2 flex items-center">
                <Gauge /> Fast
            </h2>
            <p class="mt-4">
                The sites I build have near-instant load times, work great on
                phones, and help you show up when people search for businesses
                like yours on search engines.
            </p>
        </div>
        <div class="flex flex-col">
            <h2 class="text-2xl font-semibold gap-2 flex items-center">
                <ShieldPlus /> Secure
            </h2>
            <p class="mt-4">
                I've spent years working with Linux, experimenting with web
                technologies, and building a security-first mindset. I have
                cybersecurity experience through <a
                    href="https://profile.hackthebox.com/profile/019e8872-115f-73d5-bf4e-02db0121776b"
                    target="_blank"
                    rel="noreferrer"
                    class="text-green-500 hover:text-green-700 hover:underline"
                    >Hack The Box</a
                >, where developers practice finding, exploiting and fixing real
                vulnerabilities. I'm now applying that experience and knowledge
                as a freelance web developer.
            </p>
        </div>
        <div class="flex flex-col">
            <h2 class="text-2xl font-semibold gap-2 flex items-center">
                <ArrowBigRight /> Direct
            </h2>
            <p class="mt-4">
                When you hire me, you'll be working with me directly, not an
                agency. I'll work with you to create a fast, secure website.
            </p>
        </div>
    </div>
</section>
