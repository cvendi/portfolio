---
import { Button } from "@/components/starwind/button";
import {
    Accordion,
    AccordionContent,
    AccordionItem,
    AccordionTrigger,
} from "@/components/starwind/accordion";

import { Image } from "astro:assets";
import { Sparkles } from "@lucide/astro";
import { CircleUserRound } from "@lucide/astro";
import KeyboardImage from "@/assets/keyboard.png";
import CodyImage from "@/assets/cody.jpg";
---

<section
    id="hero"
    class="flex flex-col max-w-6xl mx-auto p-6 space-y-12 min-h-screen"
>
    <div class="flex flex-col md:flex-row items-center gap-8">
        <h1 class="text-center md:text-left text-2xl md:text-6xl md:flex-1">
            I build fast, modern websites with Astro and Tailwind
        </h1>
        <Image
            src={KeyboardImage}
            alt="keyboard"
            class="w-3/4 md:w-2/5 rounded-lg shadow-lg"
        />
    </div>
    <div
        id="about"
        class="flex flex-col md:flex-row h-full items-center md:items-start gap-8 mt-24"
    >
        <Image
            src={CodyImage}
            alt="Cody Venditto"
            class="rounded-full w-2/3 md:w-2/8"
        />
        <Accordion defaultValue="item-1" class="flex-1">
            <p
                class="text-2xl font-bold mb-4 flex justify-center items-center md:justify-start gap-2"
            >
                <CircleUserRound />About Me
            </p>
            <AccordionItem value="item-1">
                <AccordionTrigger class="text-lg font-bold"
                    >Who are you?</AccordionTrigger
                >
                <AccordionContent>
                    My name is Cody. I'm a new developer looking to take on my
                    first freelance clients.
                </AccordionContent>
            </AccordionItem>
            <AccordionItem value="item-2">
                <AccordionTrigger class="text-lg font-bold"
                    >What do you do?</AccordionTrigger
                >
                <AccordionContent>
                    I'm building fast, modern websites using Astro & Tailwind,
                    the same technologies that power the websites used by some
                    of the world's top companies.
                </AccordionContent>
            </AccordionItem>
            <AccordionItem value="item-3">
                <AccordionTrigger class="text-lg font-bold"
                    >Are you accepting clients?</AccordionTrigger
                >
                <AccordionContent>
                    I'm currently taking on a limited number of projects.
                </AccordionContent>
            </AccordionItem>
            <AccordionItem value="item-4">
                <AccordionTrigger class="text-lg font-bold"
                    >Why should I choose you to make my website?</AccordionTrigger
                >
                <AccordionContent>
                    I bring years of hands-on Linux experience and a
                    security-first mindset, including hands-on security
                    coursework through <a
                        href="https://hackthebox.com/"
                        target="_blank"
                        rel="noreferrer"
                        class="text-green-500">Hack the Box</a
                    >, to every project. I'll work with you to create the
                    website you truly want and need, at a fair price.
                </AccordionContent>
            </AccordionItem>
        </Accordion>
    </div>
</section>
