---
import { Button } from "@/components/starwind/button";
import { Input } from "@/components/starwind/input";
import { Send } from "@lucide/astro";

const sitekey = import.meta.env.PUBLIC_TURNSTILE_SITEKEY;
---

<section
    id="contact"
    class="flex flex-col items-center justify-center gap-8 mt-24 mb-24 p-6"
>
    <span class="text-4xl text-center">Want to get in touch with me?</span>
    <form
        id="contact-form"
        class="flex flex-col gap-4 items-center justify-center"
    >
        <Input
            type="email"
            name="email"
            required
            size="lg"
            placeholder="you@example.com"
            class="border-gray-500"
        />

        <div
            class="cf-turnstile"
            data-sitekey={sitekey}
            data-callback="onTurnstileSuccess"
            data-error-callback="onTurnstileError"
            data-expired-callback="onTurnstileExpired"
        >
        </div>

        <Button
            id="submit-button"
            type="submit"
            size="lg"
            class="mx-auto bg-white text-black border border-black hover:bg-black hover:text-white"
            ><Send /> Send</Button
        >
        <code id="contact-status"></code>
    </form>
</section>

<script is:inline>
    const form = document.querySelector("#contact-form");
    const statusEl = document.querySelector("#contact-status");
    const button = document.getElementById("submit-button");

    // Turnstile callbacks must be global, so this script is `is:inline`.
    window.onTurnstileSuccess = () => (button.disabled = false);
    window.onTurnstileError = () => (button.disabled = true);
    window.onTurnstileExpired = () => (button.disabled = true);

    function showStatus(msg, ok) {
        if (!statusEl) return;
        statusEl.textContent = msg;
        statusEl.className = `bg-black border rounded-lg p-4 text-xl text-center flex items-center justify-center ${ok ? "text-green-400" : "text-red-600"}`;
    }

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const data = new FormData(form);
        const email = data.get("email")?.toString().trim();
        const token = data.get("cf-turnstile-response")?.toString();

        if (!email) return;
        if (!token) {
            showStatus("Turnstile verification failed.", false);
            return;
        }

        button.disabled = true;
        try {
            const res = await fetch("/api/contact", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ email, token }),
            });
            if (res.ok) {
                form.reset();
                showStatus("Thanks! I'll be in touch.", true);
            } else {
                showStatus("Something went wrong. Please try again.", false);
            }
        } catch {
            showStatus("Network error. Please try again.", false);
        } finally {
            window.turnstile?.reset(); // token is single-use; get a fresh one
            // button stays disabled until the fresh challenge re-fires onTurnstileSuccess
        }
    });
</script>
