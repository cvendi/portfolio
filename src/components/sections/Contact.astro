---
import { Button } from "@/components/starwind/button";
import { Input } from "@/components/starwind/input";
import { Textarea } from "@/components/starwind/textarea";
import { Send } from "@lucide/astro";

const sitekey = import.meta.env.PUBLIC_TURNSTILE_SITEKEY;
---

<section
    id="contact"
    class="flex flex-col items-center justify-center gap-6 mt-24 mb-24 p-6"
>
    <span class="text-4xl text-center">Want to get in touch with me?</span>
    <span class="text-lg text-center"
        >Drop a message below and I'll get back to you.</span
    >
    <form
        id="contact-form"
        class="flex flex-col gap-4 items-center justify-center md:w-120"
    >
        <Input
            type="text"
            name="name"
            required
            size="lg"
            placeholder="Your name"
            class="border-gray-500"
        />
        <Input
            type="email"
            name="email"
            required
            size="lg"
            placeholder="your@email.com"
            class="border-gray-500"
        />
        <Textarea
            name="message"
            required
            size="lg"
            placeholder="Your message..."
            class="border-gray-500 h-40"
        />

        <div
            class="cf-turnstile"
            data-sitekey={sitekey}
            data-execution="execute"
            data-appearance="interaction-only"
            data-callback="onTurnstileSuccess"
            data-error-callback="onTurnstileError"
        >
        </div>

        <Button
            id="submit-button"
            type="submit"
            size="lg"
            class="mx-auto bg-white text-black border border-black hover:bg-black hover:text-white"
            ><Send /> Send</Button
        >
        <code id="contact-status"></code>
    </form>
</section>

<script is:inline>
    // Turnstile callbacks must be global, so this script is `is:inline`.
    let resolveToken;
    window.onTurnstileSuccess = (token) => resolveToken?.(token);
    window.onTurnstileError = () => resolveToken?.(null);

    // Mints a fresh, unexpired token at call time (execution="execute"), so a
    // form that has been idle can't submit a stale token.
    window.getTurnstileToken = () =>
        new Promise((resolve) => {
            if (!window.turnstile) return resolve(null);
            const widget = document.querySelector(".cf-turnstile");
            resolveToken = resolve;
            window.turnstile.reset(widget); // clear any previous/expired token
            window.turnstile.execute(widget); // run the (invisible) challenge now
        });
</script>

<script>
    import { actions } from "astro:actions";

    const form = document.querySelector<HTMLFormElement>("#contact-form");
    const statusEl = document.querySelector("#contact-status");
    const button = document.getElementById(
        "submit-button",
    ) as HTMLButtonElement;

    function showStatus(msg: string, ok: boolean) {
        if (!statusEl) return;
        statusEl.textContent = msg;
        statusEl.className = `bg-black border rounded-lg p-4 text-xl text-center flex items-center justify-center ${ok ? "text-green-400" : "text-red-600"}`;
    }

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();

        button.disabled = true;

        try {
            const token = await (window as any).getTurnstileToken();
            if (!token) {
                showStatus("Verification failed, please try again.", false);
                return;
            }

            const formData = new FormData(form);
            formData.set("cf-turnstile-response", token);

            const { error } = await actions.submitContact(formData);
            if (error) {
                showStatus(error.message, false);
            } else {
                form.reset();
                showStatus("Thanks! We'll be in touch.", true);
            }
        } finally {
            button.disabled = false;
        }
    });
</script>
