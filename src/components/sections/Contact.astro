---
import { Button } from "@/components/starwind/button";
import { Input } from "@/components/starwind/input";
import { Textarea } from "@/components/starwind/textarea";
import { Spinner } from "@/components/starwind/spinner";
import {
    Alert,
    AlertDescription,
    AlertTitle,
} from "@/components/starwind/alert";
import { Send } from "@lucide/astro";
import Check from "@tabler/icons/outline/circle-check.svg";
import Error from "@tabler/icons/outline/circle-x.svg";

const sitekey = import.meta.env.PUBLIC_TURNSTILE_SITEKEY;
---

<section
    id="contact"
    class="flex flex-col items-center justify-center gap-6 mt-24 mb-24 p-6"
>
    <span class="text-4xl text-center">Want to get in touch with me?</span>
    <span class="text-lg text-center"
        >Drop a message below and I'll get back to you.</span
    >
    <form
        id="contact-form"
        class="flex flex-col gap-4 items-center justify-center md:w-120"
    >
        <Input
            type="text"
            name="name"
            required
            size="lg"
            placeholder="Your name"
            class="border-gray-500"
        />
        <Input
            type="email"
            name="email"
            required
            size="lg"
            placeholder="your@email.com"
            class="border-gray-500"
        />
        <Textarea
            name="message"
            required
            size="lg"
            placeholder="Your message..."
            class="border-gray-500 h-40"
        />

        <div
            class="cf-turnstile"
            data-sitekey={sitekey}
            data-execution="execute"
            data-appearance="interaction-only"
            data-callback="onTurnstileSuccess"
            data-error-callback="onTurnstileError"
        >
        </div>

        <div class="flex flex-col justify-center items-center space-y-4">
            <Button
                id="submit-button"
                type="submit"
                size="lg"
                class="bg-white text-black border border-black hover:bg-black hover:text-white"
                ><Send /> Send</Button
            >

            <Spinner id="spinner" class="size-8 hidden" />

            <Alert id="status-alert" class="hidden self-stretch w-full">
                <AlertTitle id="status-title">
                    <Check id="status-icon-success" class="hidden" />
                    <Error id="status-icon-error" class="hidden" />
                    <span id="status-title-text"></span>
                </AlertTitle>
                <AlertDescription id="status-msg" />
            </Alert>
        </div>
    </form>
</section>

<script is:inline>
    // Turnstile callbacks must be global, so this script is `is:inline`.
    let resolveToken;
    window.onTurnstileSuccess = (token) => resolveToken?.(token);
    window.onTurnstileError = () => resolveToken?.(null);

    // Mints a fresh, unexpired token at call time (execution="execute"), so a
    // form that has been idle can't submit a stale token.
    window.getTurnstileToken = () =>
        new Promise((resolve) => {
            if (!window.turnstile) return resolve(null);
            const widget = document.querySelector(".cf-turnstile");
            resolveToken = resolve;
            window.turnstile.reset(widget); // clear any previous/expired token
            window.turnstile.execute(widget); // run the (invisible) challenge now
        });
</script>

<script>
    import { actions } from "astro:actions";
    import { alert } from "@/components/starwind/alert/variants";

    const form = document.querySelector<HTMLFormElement>("#contact-form");
    const statusType = document.querySelector("#status-alert");
    const statusTitleText = document.querySelector("#status-title-text");
    const statusIconSuccess = document.querySelector("#status-icon-success");
    const statusIconError = document.querySelector("#status-icon-error");
    const statusMessage = document.querySelector("#status-msg");
    const button = document.getElementById(
        "submit-button",
    ) as HTMLButtonElement;
    const spinner = document.getElementById("spinner")!;

    function showStatus(msg: string, ok: boolean) {
        if (!statusType) return;
        statusType.classList.remove("hidden");
        statusType.className = alert({ variant: ok ? "success" : "error" });
        statusIconSuccess?.classList.toggle("hidden", !ok);
        statusIconError?.classList.toggle("hidden", ok);
        if (statusTitleText)
            statusTitleText.textContent = ok ? "Done!" : "Error";
        if (statusMessage) statusMessage.textContent = msg;
    }

    function showSpinner() {
        spinner.classList.remove("hidden");
    }

    function hideSpinner() {
        spinner.classList.add("hidden");
    }

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();

        button.disabled = true;

        try {
            const token = await (window as any).getTurnstileToken();
            if (!token) {
                showStatus("Verification failed, please try again.", false);
                return;
            }

            const formData = new FormData(form);
            formData.set("cf-turnstile-response", token);

            showSpinner();
            const { error } = await actions.submitContact(formData);
            if (error) {
                showStatus(error.message, false);
            } else {
                form.reset();
                showStatus("Message sent! I'll get back to you soon.", true);
            }
        } finally {
            hideSpinner();
            button.disabled = false;
        }
    });
</script>
