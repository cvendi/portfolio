---
import { Button } from "@/components/starwind/button";
import { Input } from "@/components/starwind/input";
import { Send } from "@lucide/astro";

const sitekey = import.meta.env.PUBLIC_TURNSTILE_SITEKEY;
---

<section
    id="contact"
    class="flex flex-col items-center justify-center gap-6 mt-24 mb-24 p-6"
>
    <span class="text-4xl text-center">Want to get in touch with me?</span>
    <span class="text-lg text-center"
        >Drop your email below and I'll get back to you.</span
    >
    <form
        id="contact-form"
        class="flex flex-col gap-4 items-center justify-center"
    >
        <Input
            type="email"
            name="email"
            required
            size="lg"
            placeholder="your@email.com"
            class="border-gray-500"
        />

        <div
            class="cf-turnstile"
            data-sitekey={sitekey}
            data-callback="onTurnstileSuccess"
            data-error-callback="onTurnstileError"
            data-expired-callback="onTurnstileExpired"
        >
        </div>

        <Button
            id="submit-button"
            type="submit"
            size="lg"
            class="mx-auto bg-white text-black border border-black hover:bg-black hover:text-white"
            ><Send /> Send</Button
        >
        <code id="contact-status"></code>
    </form>
</section>

<script is:inline>
    // Turnstile callbacks must be global, so this script is `is:inline`.
    window.onTurnstileSuccess = () => {
        document.getElementById("submit-button").disabled = false;
    };
    window.onTurnstileError = () => {
        document.getElementById("submit-button").disabled = true;
    };
    window.onTurnstileExpired = () => {
        document.getElementById("submit-button").disabled = true;
    };
</script>

<script>
    import { actions } from "astro:actions";

    const form = document.querySelector<HTMLFormElement>("#contact-form");
    const statusEl = document.querySelector("#contact-status");
    const button = document.getElementById(
        "submit-button",
    ) as HTMLButtonElement;

    function showStatus(msg: string, ok: boolean) {
        if (!statusEl) return;
        statusEl.textContent = msg;
        statusEl.className = `bg-black border rounded-lg p-4 text-xl text-center flex items-center justify-center ${ok ? "text-green-400" : "text-red-600"}`;
    }

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();

        button.disabled = true;

        try {
            const { error } = await actions.submitContact(new FormData(form));
            if (error) {
                showStatus(error.message, false);
            } else {
                form.reset();
                showStatus("Thanks! I'll be in touch.", true);
            }
        } finally {
            button.disabled = false;
            window.turnstile?.reset();
        }
    });
</script>
