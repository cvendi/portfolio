---
import { siGithub } from "simple-icons";
import { Button } from "@/components/starwind/button";
import { ThemeToggle } from "@/components/starwind/theme-toggle";

interface Props {
    item: { name: string; href: string };
}

const { item } = Astro.props;
---

{
    item.name === "Contact" ? (
        <li class="hover:text-blue-300">
            <a href={item.href}>
                <Button
                    class="bg-white text-black border border-black hover:bg-black hover:text-white transition-colors text-md"
                    size="md"
                >
                    {item.name}
                </Button>
            </a>
        </li>
    ) : item.name === "ThemeToggle" ? (
        <li>
            <ThemeToggle />
        </li>
    ) : item.name === "GitHub" ? (
        <li class="hover:text-gray-400">
            <a href={item.href} target="_blank">
                <svg
                    viewBox="0 0 24 24"
                    width="24"
                    height="24"
                    fill="currentColor"
                >
                    <path d={siGithub.path} />
                </svg>
            </a>
        </li>
    ) : (
        <li class="hover:text-gray-400">
            <a href={item.href}>{item.name}</a>
        </li>
    )
}
