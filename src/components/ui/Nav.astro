---
import Terminal from "@tabler/icons/outline/terminal-2.svg";
import NavItem from "./NavItem.astro";

const navItems = [
    { name: "About", href: "/#about" },
    { name: "Contact", href: "/#contact" },
    { name: "ThemeToggle", href: "" },
    { name: "GitHub", href: "https://github.com/cvendi/portfolio" },
];
---

<div
    class="relative mx-auto flex w-full max-w-7xl items-center px-6 py-4 sm:px-8 lg:px-10 xl:px-12 md:hidden"
>
    <a
        href="/"
        class="flex flex-1 items-center gap-4 p-4 dark:hover:bg-white dark:hover:border-white dark:hover:text-black hover:bg-black hover:border-black hover:rounded hover:text-white"
    >
        <Terminal
            class="h-10 w-10 rounded dark:bg-white dark:text-black text-white bg-black"
        />
        <span class="flex flex-col">
            <span class="font-bold text-2xl">Cody Venditto</span>
        </span>
    </a>
    <details class="mobile-nav group">
        <summary
            class="flex h-11 w-11 shrink-0 list-none items-center justify-center rounded-md border border-border text-body-text transition-colors hover:text-legendary-accent [&::-webkit-details-marker]:hidden"
        >
            <span class="sr-only">Toggle navigation menu</span>
            <svg
                class="h-6 w-6 group-open:hidden"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
            >
                <path d="M4 7h16"></path>
                <path d="M4 12h16"></path>
                <path d="M4 17h16"></path>
            </svg>
            <svg
                class="hidden h-6 w-6 group-open:block"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
            >
                <path d="M18 6 6 18"></path>
                <path d="m6 6 12 12"></path>
            </svg>
        </summary>
        <nav
            class="absolute inset-x-0 top-full z-10 border-t border-border bg-background px-6 py-6 shadow-lg sm:px-8"
        >
            <ul class="flex flex-col items-center gap-6 text-md">
                <ul class="flex items-center gap-8">
                    {
                        navItems
                            .slice(0, 3)
                            .map((item) => <NavItem item={item} />)
                    }
                </ul>
                <ul class="flex items-center gap-8">
                    {navItems.slice(3).map((item) => <NavItem item={item} />)}
                </ul>
            </ul>
        </nav>
    </details>
</div>
<nav class="hidden md:grid grid-cols-2 grid-rows-auto max-w-7xl mx-auto gap-6">
    <div
        class="col-span-2 md:col-span-1 flex justify-center md:justify-start items-center gap-4"
    >
        <a
            href="/"
            class="flex items-center gap-4 p-4 hover:text-gray-400 hover:underline hover:decoration-dashed hover:decoration-3 hover:underline-offset-10"
        >
            <Terminal class="h-10 w-10 rounded dark:text-white text-black" />

            <span class="flex flex-col">
                <span class="font-bold text-2xl md:text-3xl">Cody Venditto</span
                >
            </span>
        </a>
    </div>
    <div
        class="col-start-1 row-start-2 col-span-2 md:row-start-1 md:col-start-2 md:col-span-1 flex items-center md:justify-end justify-center"
    >
        <ul class="flex items-center gap-8 text-md md:text-xl">
            {navItems.map((item) => <NavItem item={item} />)}
        </ul>
    </div>
    <div class="md:row-start-2 row-start-3 col-span-2">
        <hr class="w-full" />
    </div>
</nav>
