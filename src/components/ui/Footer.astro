---
import { siGithub, siX } from "simple-icons";
---

<footer class="flex justify-center items-center p-12 text-sm opacity-50">
    <div class="flex flex-col items-center gap-2 space-y-4">
        <p>&copy; 2026 Cody Venditto</p>
        <div class="flex gap-4">
            <a href="https://github.com/cvendi" target="_blank">
                <svg
                    viewBox="0 0 24 24"
                    width="24"
                    height="24"
                    fill="currentColor"
                >
                    <path d={siGithub.path}></path>
                </svg>
            </a>
            <a href="https://x.com/vendittodev" target="_blank">
                <svg
                    viewBox="0 0 24 24"
                    width="24"
                    height="24"
                    fill="currentColor"
                >
                    <path d={siX.path}></path>
                </svg>
            </a>
        </div>
    </div>
</footer>
